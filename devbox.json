{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.2/.schema/devbox.schema.json",
  "packages": [
    "python@3.13.3",
    "uv@0.7.17",
  ],
  "shell": {
    "init_hook": [
      "uv sync"
    ],
    "scripts": {
      "generate": [
        "uv sync",
        "uv run --frozen python main.py"
      ],
      "lock": [
        "uv lock",
        "uv export --format=requirements.txt -o requirements.txt"
      ]
    },
  },
}
